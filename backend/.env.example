# Scanify Backend Environment Example
# Copy to .env and fill in values. Do NOT commit the real .env

# Gemini / Google Generative AI
GEMINI_API_KEY=YOUR_SECURE_API_KEY
# or
# GOOGLE_API_KEY=YOUR_SECURE_API_KEY

# Tesseract OCR (local, free)
# Windows: Download from https://github.com/UB-Mannheim/tesseract/wiki
# Linux/Docker: Already installed
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR engine selection: 'tesseract' (default) or 'olmocr'
OCR_ENGINE=tesseract
OLMOCR_MAX_NEW_TOKENS=512

# Flask
PORT=5000

# Disable OCR (set to 1/true to disable image analysis)
DISABLE_OCR=0
