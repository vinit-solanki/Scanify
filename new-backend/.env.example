# Default Configuration
# Copy and modify as needed for your environment

# Server Configuration
PORT=5000
HOST=0.0.0.0
FLASK_ENV=development

# OCR Configuration
OCR_ENGINE=tesseract
TESSERACT_PATH=/usr/bin/tesseract

# For Windows (uncomment and use)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR Model Configuration
OLMOCR_MAX_NEW_TOKENS=512

# Upload Configuration
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE_MB=10
MAX_TEXT_LENGTH=10000

# API Configuration
CORS_ORIGINS=["*"]
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_ANALYSES=8
RATE_LIMIT_RPM=120

# OpenRouter API (Optional - for AI-powered explanations)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=15
OPENROUTER_QUOTA_COOLDOWN_SECONDS=120
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=Scanify

# Logging Configuration
LOG_LEVEL=INFO

# Health Scoring Configuration
DEFAULT_ANALYSIS_MODE=weight_loss
CONFIDENCE_THRESHOLD=0.5
